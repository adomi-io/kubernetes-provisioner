# Copy to .env and fill in. The installer loads it automatically.
# Using helmfile directly? Run: export $(grep -v '^#' .env | xargs)

DOMAIN=example.com
ACME_EMAIL=you@example.com

# Where Argo CD reads the platform from (your fork if you customize it).
GIT_REPO_URL=https://github.com/adomi-io/kubernetes-provisioner.git
GIT_TARGET_REVISION=main

# OpenBao unseal: "kubernetes" (default, self-managed) or "kms" (cloud KMS).
# BAO_UNSEAL_MODE=kms

# For kms mode: a seal stanza plus a service-account annotation for KMS access.
# BAO_SEAL_CONFIG='seal "awskms" { region = "us-east-1" kms_key_id = "<arn-or-id>" }'
# BAO_SA_ANNOTATION_KEY=eks.amazonaws.com/role-arn
# BAO_SA_ANNOTATION_VALUE=arn:aws:iam::<account>:role/openbao-unseal

# Defaults are fine; override only if you need to.
# BAO_ADDR=http://openbao.openbao.svc.cluster.local:8200
# BAO_KV_MOUNT=secret
# BAO_KUBERNETES_AUTH_MOUNT=kubernetes
# BAO_KUBERNETES_AUTH_ROLE=external-secrets
# BAO_AUTHENTIK_SECRET_PATH=authentik
# BAO_ARGO_WORKFLOWS_SECRET_PATH=argo-workflows
# INGRESS_CLASS=traefik
# CLUSTER_ISSUER=letsencrypt-prod
