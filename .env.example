# Copy to .env and fill in your values. The installer loads .env automatically.
#
# Running `helmfile` directly instead of through the installer? Export them first:
#   export $(grep -v '^#' .env | xargs)
#   helmfile apply

# --- Required ---
DOMAIN=example.com
ACME_EMAIL=you@example.com

# --- Argo CD's GitOps source (your own fork/branch if you customize argocd/) ---
GIT_REPO_URL=https://github.com/adomi-io/kubernetes-provisioner.git
GIT_TARGET_REVISION=main

# --- OpenBao: where your secrets live ---
# Defaults to the in-cluster OpenBao this repo installs. Only set BAO_ADDR if you
# run your own OpenBao elsewhere.
# BAO_ADDR=http://openbao.openbao.svc.cluster.local:8200

# --- Optional: auto-unseal via a cloud KMS (otherwise you unseal by hand) ---
# BAO_SEAL_CONFIG is a raw HCL `seal` stanza for your cloud (README has GCP/Azure
# examples). Give OpenBao KMS access with the service-account annotation.
# BAO_SEAL_CONFIG='seal "awskms" { region = "us-east-1" kms_key_id = "<arn-or-id>" }'
# BAO_SA_ANNOTATION_KEY=eks.amazonaws.com/role-arn
# BAO_SA_ANNOTATION_VALUE=arn:aws:iam::<account>:role/openbao-unseal
BAO_KV_MOUNT=secret
BAO_KUBERNETES_AUTH_MOUNT=kubernetes
BAO_KUBERNETES_AUTH_ROLE=external-secrets
BAO_AUTHENTIK_SECRET_PATH=authentik
BAO_ARGO_WORKFLOWS_SECRET_PATH=argo-workflows

# --- Optional: only if you swap out Traefik / the Let's Encrypt issuer ---
# INGRESS_CLASS=traefik
# CLUSTER_ISSUER=letsencrypt-prod
